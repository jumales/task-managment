# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=demo
POSTGRES_PASSWORD=demo123

# ─── Keycloak ─────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# Issuer URI used by all microservices to validate JWT signatures
KEYCLOAK_ISSUER_URI=http://localhost:8180/realms/demo
# Token endpoint used by notification-service (client_credentials flow)
KEYCLOAK_TOKEN_URI=http://localhost:8180/realms/demo/protocol/openid-connect/token
# OAuth2 client secret for notification-service
KEYCLOAK_CLIENT_SECRET=notification-secret
# OAuth2 client secret for user-service (Keycloak Admin REST API)
KEYCLOAK_USER_SERVICE_CLIENT_SECRET=user-service-secret

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123

# ─── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
