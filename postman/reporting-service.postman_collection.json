{
  "info": {
    "_postman_id": "e5f6a7b8-c9d0-1234-efab-345678901234",
    "name": "Reporting Service",
    "description": "Reporting endpoints: my tasks (all / 5d / 30d) and planned-vs-booked hours.\n\nEndpoints are added as the feature is implemented — this scaffold collection currently asserts the health endpoint only.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{bearerToken}}", "type": "string" }
    ]
  },
  "variable": [],
  "item": [
    {
      "name": "My Tasks",
      "item": [
        {
          "name": "All my tasks",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/reports/my-tasks",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "reports", "my-tasks"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "My tasks (last 5 days)",
          "request": {
            "method": "GET",
            "header": [],
