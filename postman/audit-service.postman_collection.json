{
  "info": {
    "_postman_id": "c3d4e5f6-a7b8-9012-cdef-123456789012",
    "name": "Audit Service",
    "description": "Query the change history of tasks.\n\nRequires a `taskId` that was produced by task-service. Set it manually in collection variables or run the task-service collection first and copy the value.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{bearerToken}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "taskId", "value": "" }
  ],
  "item": [
    {
      "name": "Audit",
      "item": [
        {
          "name": "Get status change history",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/audit/tasks/{{taskId}}/statuses",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "audit", "tasks", "{{taskId}}", "statuses"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response is array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get comment history",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/audit/tasks/{{taskId}}/comments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "audit", "tasks", "{{taskId}}", "comments"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response is array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get phase change history",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/audit/tasks/{{taskId}}/phases",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "audit", "tasks", "{{taskId}}", "phases"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response is array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "DLQ",
      "item": [
        {
          "name": "Get DLT consumer lag",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/dlq/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "dlq", "status"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has dltConsumerLag', () => pm.expect(pm.response.json()).to.have.property('dltConsumerLag'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
}
