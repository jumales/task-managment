{
  "info": {
    "_postman_id": "d4e5f6a7-b8c9-0123-defa-234567890123",
    "name": "Notification Service",
    "description": "Query email notification history for tasks.\n\nRequires a `taskId` from task-service. Set it manually in collection variables or run the task-service collection first.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{bearerToken}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "taskId", "value": "" }
  ],
  "item": [
    {
      "name": "Notifications",
      "item": [
        {
          "name": "Get notification history for task",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/notifications/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "notifications", "tasks", "{{taskId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response is array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
}
