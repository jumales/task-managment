                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Update avatar",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fileId\": \"{{fileId}}\"\n}",
