{
  "info": {
    "_postman_id": "a1b2c3d4-e5f6-7890-abcd-ef1234567890",
    "name": "User Service",
    "description": "Users, Roles and Rights management.\n\nCreate requests automatically save the returned ID into a collection variable (e.g. `userId`) so subsequent requests can reference it without manual copy-paste.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{bearerToken}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "userId",  "value": "" },
    { "key": "roleId",  "value": "" },
    { "key": "rightId", "value": "" },
    { "key": "fileId",  "value": "" }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Get all users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users?page=0&size=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "20" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "var json = pm.response.json();",
                  "pm.test('Response is paginated', () => {",
                  "  pm.expect(json).to.have.property('content');",
                  "  pm.expect(json).to.have.property('totalElements');",
                  "  pm.expect(json.content).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get users by IDs (batch)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/batch?ids={{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "batch"],
              "query": [{ "key": "ids", "value": "{{userId}}", "description": "Comma-separated or repeated UUID params" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response is array', () => pm.expect(pm.response.json()).to.be.an('array'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get user by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "{{userId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has id', () => pm.expect(pm.response.json()).to.have.property('id'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Create user",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Johnson\",\n  \"email\": \"alice@demo.com\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('userId', json.id);",
                  "pm.test('ID saved to userId', () => pm.expect(json.id).to.be.a('string'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Update user",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Johnson Updated\",\n  \"email\": \"alice.updated@demo.com\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "{{userId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Name updated', () => pm.expect(pm.response.json().name).to.include('Updated'));"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Assign role to user",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}/roles/{{roleId}}?assignedBy=admin",
