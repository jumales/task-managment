            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/{{userId}}/avatar",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "users", "{{userId}}", "avatar"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('avatarFileId is null', () => pm.expect(pm.response.json().avatarFileId).to.be.null);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
