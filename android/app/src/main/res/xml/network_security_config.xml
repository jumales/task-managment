<?xml version="1.0" encoding="utf-8"?>
<!--
  Permits cleartext HTTP only for known dev hosts.
  This file is referenced only from the debug build type manifest placeholder.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <!-- Android emulator host loopback alias -->
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- LAN range for physical device testing -->
        <domain includeSubdomains="false">192.168.0.0/16</domain>
        <!-- Localhost -->
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
