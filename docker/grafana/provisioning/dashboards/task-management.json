{
  "annotations": { "list": [] },
  "description": "Task Management microservices – HTTP traffic, JVM health, DB connections, Kafka",
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["spring-boot", "task-management"],
  "title": "Task Management – Overview",
  "uid": "task-mgmt-overview",
  "version": 1,
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {},
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Requests / s",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 200 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"spring-services\"}[2m]))",
          "legendFormat": "RPS",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "5xx Error Rate",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"spring-services\",status=~\"5..\"}[2m])) / sum(rate(http_server_requests_seconds_count{job=\"spring-services\"}[2m]))",
          "legendFormat": "Error %",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "p99 Response Time (all services)",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"spring-services\"}[2m])) by (le))",
          "legendFormat": "p99",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "id": 10,
      "type": "row",
      "title": "HTTP Traffic",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Requests / s by Service",
      "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"spring-services\"}[2m])) by (application)",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "5xx Errors / s by Service",
      "gridPos": { "x": 12, "y": 5, "w": 12, "h": 8 },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineWidth": 2 },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.1 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"spring-services\",status=~\"5..\"}[2m])) by (application)",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "p99 Latency by Service",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 8 },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"spring-services\"}[2m])) by (le, application))",
          "legendFormat": "{{application}} p99",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"spring-services\"}[2m])) by (le, application))",
          "legendFormat": "{{application}} p50",
          "refId": "B"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "id": 11,
      "type": "row",
      "title": "JVM Health",
      "gridPos": { "x": 0, "y": 21, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "JVM Heap Used",
      "gridPos": { "x": 0, "y": 22, "w": 12, "h": 8 },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": { "unit": "bytes", "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{job=\"spring-services\", area=\"heap\"}) by (application)",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "JVM Live Threads",
      "gridPos": { "x": 12, "y": 22, "w": 12, "h": 8 },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } },
        "overrides": []
      },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=\"spring-services\"}",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "id": 12,
      "type": "row",
      "title": "Database & Kafka",
      "gridPos": { "x": 0, "y": 30, "w": 24, "h": 1 },
      "collapsed": false
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "HikariCP Active Connections",
      "gridPos": { "x": 0, "y": 31, "w": 12, "h": 8 },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 8 },
              { "color": "red", "value": 15 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "hikaricp_connections_active{job=\"spring-services\"}",
          "legendFormat": "{{application}} active",
          "refId": "A"
        },
        {
          "expr": "hikaricp_connections_pending{job=\"spring-services\"}",
          "legendFormat": "{{application}} pending",
          "refId": "B"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Kafka Consumer Lag",
      "gridPos": { "x": 12, "y": 31, "w": 12, "h": 8 },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "expr": "sum(spring_kafka_listener_seconds_count{job=\"spring-services\"}) by (application)",
          "legendFormat": "{{application}}",
          "refId": "A"
        }
      ],
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" }
    }
  ],
  "templating": {
    "list": [
      {
        "hide": 2,
        "name": "DS_PROMETHEUS",
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  }
}
