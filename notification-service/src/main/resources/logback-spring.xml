<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <springProperty scope="context" name="appName" source="spring.application.name" defaultValue="notification-service"/>

    <!-- JSON console output — structured logs readable by Filebeat / Logstash -->
    <appender name="JSON_CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <!-- Static field added to every log line so Kibana can filter by service -->
            <customFields>{"service":"${appName}"}</customFields>
        </encoder>
    </appender>

    <!--
        logstash profile: also ship logs directly to Logstash via TCP.
        Activate with: spring.profiles.active=logstash
        The destination host must match the Logstash service name in docker-compose.
    -->
    <springProfile name="logstash">
        <appender name="LOGSTASH" class="net.logstash.logback.appender.LogstashTcpSocketAppender">
            <destination>${logback.destination:-logstash:5000}</destination>
            <encoder class="net.logstash.logback.encoder.LogstashEncoder">
                <customFields>{"service":"${appName}"}</customFields>
            </encoder>
        </appender>
        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
            <appender-ref ref="LOGSTASH"/>
        </root>
    </springProfile>

    <springProfile name="!logstash">
        <root level="INFO">
            <appender-ref ref="JSON_CONSOLE"/>
        </root>
    </springProfile>

</configuration>
